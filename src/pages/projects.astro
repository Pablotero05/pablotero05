---
import { Image } from 'astro:assets';
import H1 from "../components/h1.astro";
import InfoLayout from "../layouts/InfoLayout.astro";
import Meloso from "../assets/Meloso.png";
import Banana from "../assets/Banana.png";
import OSPA from "../assets/OSPA.png";

const projects = [
     {
          title: "Meloso Brunch",
          description: "Web moderna y amigable para Melosobrunch Brunch & Coffee con chatbot vectorial integrado",
          image: Meloso,
          web: "https://pablotero05.github.io/MELOSOBRUNCH/"
     },
     {
          title: "Banana Verde",
          description: "Web moderna, colorida y responsive para el chiringuito Banana Verde",
          image: Banana,
          web: "https://pablotero05.github.io/BANANAVERDE/"
     },
     {
          title: "O'SPA",
          description: "Web moderna inspirada en el sector cinematográfico para el local O'SPA",
          image: OSPA,
          web: "https://pablotero05.github.io/BANANAVERDE/"
     }];
---

<InfoLayout>
     <div class="p-2 sm:p-4 sm:pt-8 pb-20 min-h-dvh px-2 sm:px-8">  <!-- ← px más pequeños -->
          <H1> Proyectos </H1>

          <ul class="mt-4 sm:mt-12 
                    grid grid-cols-1 
                    md:grid-cols-2           <!-- ← Solo 2 columnas desktop -->
                    gap-8 sm:gap-12 lg:gap-16">  <!-- ← Gaps grandes -->
          {projects.map((project) => (
               <li class="h-full">
               <a href={project.web} 
                    class="group block h-full p-6 sm:p-8 border border-blue-500/20 
                         hover:border-blue-400 rounded-2xl hover:scale-105 
                         hover:shadow-2xl hover:shadow-blue-500/25 
                         hover:-translate-y-2 hover:bg-blue-900/20 
                         transition-all duration-300 w-full">
                    <!-- Contenido igual -->
                    <div class="flex flex-col h-full">
                    <div class="flex-shrink-0 mb-6">
                    <img 
                         src={project.image.src} 
                         alt={project.title} 
                         width={project.image.width}
                         height={project.image.height}
                         class="w-full aspect-[3/2] object-cover rounded-xl shadow-xl"  <!-- ← aspect más ancho -->
                    />
                    </div>
                    <div class="flex-1 flex flex-col justify-end space-y-2">
                    <h2 class="text-xl font-bold text-white">{project.title}</h2>
                    <p class="text-base text-zinc-300 leading-relaxed">{project.description}</p>
                    </div>
                    </div>
               </a>
               </li>
          ))}
          </ul>
     </div>
</InfoLayout>
