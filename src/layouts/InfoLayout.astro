---
import RootLayout from "./RootLayout.astro";
import Footer from "../components/footer.astro";
import WarpBackground from "../components/warp-background";

const { title, description } = Astro.props;

const pathname = Astro.url.pathname;
---

<RootLayout title={title} description={description}>
  <div class="flex w-full">  <!-- ← w-full sin max-w -->
    <nav class="relative w-16 sm:w-20 md:w-24 xl:w-32 flex-shrink-0">  <!-- ← Ancho fijo -->
      <div class="w-full h-screen sm:min-h-screen rounded-r-full overflow-hidden -z-10">
        <WarpBackground
          color1="#000000"
          color2="#000272"
          color3="#19dcff"
          speed={0.15}
          swirl={1.5}
          swirlIterations={10}
          shapeScale={0.3}
          client:load
        />
      </div>
    </nav>

    <main class="w-full ml-[-4rem] sm:ml-[-5rem] md:ml-[-6rem] xl:ml-[-8rem] pr-0">
      <!-- ← ml negativo = compensa nav + gap anterior, w-full pr-0 = sin margen derecho -->
      <slot />
      <Footer />
    </main>
  </div>
</RootLayout>


